# ============================================================
# PHANTOM OSINT Platform — Environment Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=phantom
POSTGRES_USER=phantom
POSTGRES_PASSWORD=phantom_dev_password_change_me
DATABASE_URL=postgresql+asyncpg://phantom:phantom_dev_password_change_me@postgres:5432/phantom

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ============================================================
# OPTIONAL: External API Keys
# All transforms work without these (with reduced functionality)
# ============================================================

# Numverify — Phone number validation
# https://numverify.com — Free tier: 100 req/month
NUMVERIFY_API_KEY=

# Shodan — IP/Domain intelligence
# https://shodan.io — Free tier available
SHODAN_API_KEY=

# OpenCNAM — Caller ID / CNAM lookup
# https://opencnam.com — Pay-per-use
OPENCNAM_SID=
OPENCNAM_AUTH_TOKEN=

# HaveIBeenPwned — Breach database lookup
# https://haveibeenpwned.com/API/Key — $3.50/month
HIBP_API_KEY=

# Telegram Bot — Profile lookup via bot API
# https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ============================================================
# OPTIONAL: Proxy / Anonymization
# ============================================================

# SOCKS5 proxy (e.g. Tor: socks5://127.0.0.1:9050)
PROXY_URL=
# Modules to route through proxy (comma-separated, or "all")
PROXY_MODULES=
